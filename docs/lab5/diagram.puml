@startuml
' ============================================
' 0. MANUAL CONFIGURATION
' ============================================
skinparam backgroundColor #FFFFFF
skinparam linetype ortho
skinparam shadowing false
skinparam roundcorner 8

skinparam nodesep 60
skinparam ranksep 60
skinparam class {
    BackgroundColor #F8F9FA
    BorderColor #2F4F4F
    ArrowColor #2F4F4F
}

' ============================================
' 1. LEGEND
' ============================================
legend top right
|= Access Modifiers |= |
| <color:Green>●</color> | public |
| <color:GoldenRod>◆</color>| protected |
| <color:Red>■</color> | private |
end legend

' ============================================
' 2. EXTERNAL TYPES
' ============================================
package "external" {
    interface Comparable <<Java>>
    interface Serializable <<Java>>
    class Exception <<Java>>
    class RuntimeException <<Java>>
    class Formatter <<Java>>
}

' ============================================
' 3. CLIENT
' ============================================
package "client" {
    class Client <<utility>> {
        - Client()
        + {static} main(args: String[]): void
    }
}

' ============================================
' 4. COMMON MODULE
' ============================================
package "common.models" {
    class SpaceMarine {
        - id: Integer
        - name: String
        - coordinates: Coordinates
        - creationDate: Date
        - health: float
        - height: long
        - category: AstartesCategory
        - meleeWeapon: MeleeWeapon
        - chapter: Chapter
        + SpaceMarine(name: String, coordinates: Coordinates, health: float, height: long, category: AstartesCategory, meleeWeapon: MeleeWeapon, chapter: Chapter)
        + validate(): void
        + getId(): Integer
        + setId(id: Integer): void
        + getName(): String
        + setName(name: String): void
        + getCreationDate(): Date
        + setCreationDate(creationDate: Date): void
        + getHealth(): float
        + getCoordinates(): Coordinates
        + getHeight(): long
        + getCategory(): AstartesCategory
        + getMeleeWeapon(): MeleeWeapon
        + getChapter(): Chapter
        + compareTo(o: SpaceMarine): int
        + equals(o: Object): boolean
        + hashCode(): int
        + toString(): String
    }

    class Coordinates {
        - x: double
        - y: long
        + Coordinates(x: double, y: long)
        + getX(): double
        + getY(): long
        + equals(o: Object): boolean
        + hashCode(): int
        + toString(): String
    }

    class Chapter {
        - name: String
        - parentLegion: String
        + Chapter(name: String, parentLegion: String)
        + getName(): String
        + getParentLegion(): String
        + setName(name: String): void
        + compareTo(o: Chapter): int
        + equals(o: Object): boolean
        + hashCode(): int
        + toString(): String
    }

    enum AstartesCategory {
        SCOUT
        DREADNOUGHT
        ASSAULT
        SUPPRESSOR
        APOTHECARY
    }

    enum MeleeWeapon {
        CHAIN_SWORD
        POWER_SWORD
        CHAIN_AXE
        MANREAPER
        POWER_FIST
    }
}

package "common.dto.request" {
    class CommandRequest <<DTO>> {
        - commandName: String
        - commandArguments: String[]
        + CommandRequest(commandName: String, commandArguments: String[])
        + getCommandName(): String
        + getCommandArguments(): String[]
    }
}

package "common.dto.response" {
    class CommandResponse <<DTO>> {
        - success: boolean
        - message: String
        - exitRequested: boolean
        + CommandResponse(success: boolean, message: String, exitRequested: boolean)
        + {static} success(message: String, exitRequested: boolean): CommandResponse
        + {static} failure(message: String): CommandResponse
        + isSuccess(): boolean
        + getMessage(): String
        + isExitRequested(): boolean
    }
}

package "common.util" {
    class Validator <<utility>> {
        - Validator()
        + {static} isValidString(str: String): boolean
        + {static} isGreaterThan(value: double, min: double): boolean
        + {static} validateString(s: String, fieldName: String): void
        + {static} validateGreaterThan(value: double, min: double, fieldName: String): void
        + {static} validateNotNull(value: Object, fieldName: String): void
        + {static} validateId(id: Integer): void
    }
}

package "common.exceptions" {
    class ValidationException <<Exception>> {
        + ValidationException(message: String)
    }
}

' ============================================
' 5. SERVER COMMANDS
' ============================================
package "server.commands" {
    interface CommandContract {
        + getName(): String
        + getArgs(): String
        + getDescription(): String
        + execute(args: String[]): String
        + shouldExit(): boolean
    }

    abstract class Command {
        - name: String
        - arguments: String
        - description: String
        + Command(name: String, arguments: String, description: String)
        + Command(name: String, description: String)
        + getName(): String
        + getArgs(): String
        + getDescription(): String
        + {abstract} execute(args: String[]): String
        + shouldExit(): boolean
    }

    class AddCommand {
        - collectionManager: CollectionManager
        - inputHandler: InputHandler
        + AddCommand(collectionManager: CollectionManager, inputHandler: InputHandler)
        + execute(args: String[]): String
    }

    class AddIfMinCommand {
        - collectionManager: CollectionManager
        - inputHandler: InputHandler
        + AddIfMinCommand(collectionManager: CollectionManager, inputHandler: InputHandler)
        + execute(args: String[]): String
    }

    class UpdateCommand {
        - collectionManager: CollectionManager
        - inputHandler: InputHandler
        + UpdateCommand(collectionManager: CollectionManager, inputHandler: InputHandler)
        + execute(args: String[]): String
    }

    class RemoveByIdCommand {
        - collectionManager: CollectionManager
        + RemoveByIdCommand(collectionManager: CollectionManager)
        + execute(args: String[]): String
    }

    class ClearCommand {
        - collectionManager: CollectionManager
        + ClearCommand(collectionManager: CollectionManager)
        + execute(args: String[]): String
    }

    class ShowCommand {
        - collectionManager: CollectionManager
        + ShowCommand(collectionManager: CollectionManager)
        + execute(args: String[]): String
    }

    class InfoCommand {
        - collectionManager: CollectionManager
        + InfoCommand(collectionManager: CollectionManager)
        + execute(args: String[]): String
    }

    class HeadCommand {
        - collectionManager: CollectionManager
        + HeadCommand(collectionManager: CollectionManager)
        + execute(args: String[]): String
    }

    class SumOfHealthCommand {
        - collectionManager: CollectionManager
        + SumOfHealthCommand(collectionManager: CollectionManager)
        + execute(args: String[]): String
    }

    class MaxByChapterCommand {
        - collectionManager: CollectionManager
        + MaxByChapterCommand(collectionManager: CollectionManager)
        + execute(args: String[]): String
    }

    class CountByCategoryCommand {
        - collectionManager: CollectionManager
        + CountByCategoryCommand(collectionManager: CollectionManager)
        + execute(args: String[]): String
    }

    class HelpCommand {
        - commandManager: CommandManager
        + HelpCommand(commandManager: CommandManager)
        + execute(args: String[]): String
    }

    class HistoryCommand {
        - commandManager: CommandManager
        + HistoryCommand(commandManager: CommandManager)
        + execute(args: String[]): String
    }

    class ExitCommand {
        + ExitCommand()
        + execute(args: String[]): String
        + shouldExit(): boolean
    }

    class SaveCommand {
        - collectionManager: CollectionManager
        - fileManager: FileManager
        + SaveCommand(collectionManager: CollectionManager, fileManager: FileManager)
        + execute(args: String[]): String
    }

    class ExecuteScriptCommand {
        - commandExecutor: CommandExecutor
        - inputHandler: InputHandler
        - commandRequestParser: CommandRequestParser
        - exitRequested: boolean
        + ExecuteScriptCommand(commandExecutor: CommandExecutor, inputHandler: InputHandler, commandRequestParser: CommandRequestParser)
        + execute(args: String[]): String
        + shouldExit(): boolean
    }
}

' ============================================
' 6. SERVER COMMAND FACTORY
' ============================================
package "server.commands.factory" {
    interface CommandFactory {
        + createCommands(): Map<String, CommandContract>
    }

    class CommandRegistry {
        - commands: Map<String, CommandContract>
        + register(command: CommandContract): void
        + toMap(): Map<String, CommandContract>
    }

    class DefaultCommandFactory <<factory>> {
        - commandManager: CommandManager
        - commandExecutor: CommandExecutor
        - collectionManager: CollectionManager
        - inputHandler: InputHandler
        - commandRequestParser: CommandRequestParser
        - fileManager: FileManager
        + DefaultCommandFactory(commandManager: CommandManager, commandExecutor: CommandExecutor, collectionManager: CollectionManager, inputHandler: InputHandler, commandRequestParser: CommandRequestParser, fileManager: FileManager)
        + createCommands(): Map<String, CommandContract>
    }
}

' ============================================
' 7. SERVER MANAGERS
' ============================================
package "server.managers" {
    interface CommandExecutor {
        + execute(request: CommandRequest): CommandResponse
    }

    class CommandManager {
        - commands: Map<String, CommandContract>
        - history: List<String>
        + register(command: CommandContract): void
        + registerAll(commandMap: Map<String, CommandContract>): void
        + execute(request: CommandRequest): CommandResponse
        + addToHistory(name: String, args: String): void
        + getHistory(): List<String>
        + getCommands(): Map<String, CommandContract>
    }

    class CollectionManager {
        - collection: LinkedList<SpaceMarine>
        - intializationDate: Date
        - nextId: AtomicInteger
        + add(spaceMarine: SpaceMarine): void
        + update(id: int, newSpaceMarine: SpaceMarine): void
        + getById(id: int): SpaceMarine
        + removeById(id: int): boolean
        + clear(): void
        + head(): SpaceMarine
        + addIfMin(spaceMarine: SpaceMarine): boolean
        + sumOfHealth(): float
        + maxByChapter(): SpaceMarine
        + countByCategory(category: AstartesCategory): long
        + getCollection(): LinkedList<SpaceMarine>
        + setCollection(loaded: LinkedList<SpaceMarine>): void
        + size(): int
        + getType(): String
        + getInitializationDateFormatted(): String
    }

    class FileManager {
        - filePath: String
        - gson: Gson
        + FileManager(filePath: String)
        + load(): LinkedList<SpaceMarine>
        + save(collection: LinkedList<SpaceMarine>): void
    }
}

package "server.managers.proxy" {
    class LoggingCommandExecutorProxy <<proxy>> {
        - delegate: CommandExecutor
        + LoggingCommandExecutorProxy(delegate: CommandExecutor)
        + execute(request: CommandRequest): CommandResponse
    }

    class ValidatingCommandExecutorProxy <<proxy>> {
        - delegate: CommandExecutor
        + ValidatingCommandExecutorProxy(delegate: CommandExecutor)
        + execute(request: CommandRequest): CommandResponse
    }
}

' ============================================
' 8. SERVER IO
' ============================================
package "server.io" {
    class InputHandler {
        - scanner: Scanner
        + InputHandler(scanner: Scanner)
        + getScanner(): Scanner
        + setScanner(scanner: Scanner): void
        + readSpaceMarine(): SpaceMarine
        + readSpaceMarine(current: SpaceMarine): SpaceMarine
    }

    class CommandReader {
        - scanner: Scanner
        + CommandReader(scanner: Scanner)
        + readRawCommand(): String
    }

    class CommandRequestParser {
        + toRequest(rawCommand: String): CommandRequest
    }

    class CommandOutput {
        + printPrompt(): void
        + printMessage(message: String): void
        + printError(message: String): void
        + printResponse(response: CommandResponse): void
    }
}

' ============================================
' 9. SERVER APPLICATION
' ============================================
package "server.app" {
    class ApplicationContext {
        - commandExecutor: CommandExecutor
        - commandReader: CommandReader
        - commandRequestParser: CommandRequestParser
        - commandOutput: CommandOutput
        + ApplicationContext(commandExecutor: CommandExecutor, commandReader: CommandReader, commandRequestParser: CommandRequestParser, commandOutput: CommandOutput)
        + getCommandExecutor(): CommandExecutor
        + getCommandReader(): CommandReader
        + getCommandRequestParser(): CommandRequestParser
        + getCommandOutput(): CommandOutput
    }

    class ApplicationBootstrap {
        + bootstrap(filePath: String, scanner: Scanner): ApplicationContext
    }

    class ApplicationRunner {
        - context: ApplicationContext
        + ApplicationRunner(context: ApplicationContext)
        + run(): void
    }
}

package "server.logging" {
    class LoggingConfigurator <<utility>> {
        - LoggingConfigurator()
        + {static} configureFileLogging(): void
    }

    class PrettyLogFormatter <<static inner>> {
        + format(record: LogRecord): String
    }
}

package "server" {
    class Server <<utility>> {
        - Server()
        + {static} main(args: String[]): void
    }
}

package "server.exceptions" {
    class CommandExecutionException <<Exception>> {
        + CommandExecutionException(message: String)
    }

    class FileReadException <<Exception>> {
        + FileReadException(message: String, cause: Throwable)
    }

    class FileWriteException <<Exception>> {
        + FileWriteException(message: String, cause: Throwable)
    }
}

' ============================================
' 10. RELATIONSHIPS
' ============================================
' Common inheritance and DTO markers
SpaceMarine .up.|> Comparable
Chapter .up.|> Comparable
CommandRequest .up.|> Serializable
CommandResponse .up.|> Serializable

ValidationException -up-|> RuntimeException
CommandExecutionException -up-|> Exception
FileReadException -up-|> RuntimeException
FileWriteException -up-|> RuntimeException

' Domain model composition
SpaceMarine *-- Coordinates
SpaceMarine o-- Chapter
SpaceMarine --> AstartesCategory
SpaceMarine --> MeleeWeapon

SpaceMarine .right.> Validator
Coordinates .right.> Validator
Chapter .right.> Validator
Validator .down.> ValidationException

' Command hierarchy
Command .up.|> CommandContract
AddCommand -up-|> Command
AddIfMinCommand -up-|> Command
UpdateCommand -up-|> Command
RemoveByIdCommand -up-|> Command
ClearCommand -up-|> Command
ShowCommand -up-|> Command
InfoCommand -up-|> Command
HeadCommand -up-|> Command
SumOfHealthCommand -up-|> Command
MaxByChapterCommand -up-|> Command
CountByCategoryCommand -up-|> Command
HelpCommand -up-|> Command
HistoryCommand -up-|> Command
ExitCommand -up-|> Command
SaveCommand -up-|> Command
ExecuteScriptCommand -up-|> Command

CommandContract .down.> CommandExecutionException
CommandManager .up.|> CommandExecutor
LoggingCommandExecutorProxy .up.|> CommandExecutor
ValidatingCommandExecutorProxy .up.|> CommandExecutor
DefaultCommandFactory .up.|> CommandFactory
PrettyLogFormatter -up-|> Formatter

' Command dependencies
AddCommand --> CollectionManager
AddCommand --> InputHandler
AddIfMinCommand --> CollectionManager
AddIfMinCommand --> InputHandler
UpdateCommand --> CollectionManager
UpdateCommand --> InputHandler
RemoveByIdCommand --> CollectionManager
ClearCommand --> CollectionManager
ShowCommand --> CollectionManager
InfoCommand --> CollectionManager
HeadCommand --> CollectionManager
SumOfHealthCommand --> CollectionManager
MaxByChapterCommand --> CollectionManager
CountByCategoryCommand --> CollectionManager
HelpCommand --> CommandManager
HistoryCommand --> CommandManager
SaveCommand --> CollectionManager
SaveCommand --> FileManager
ExecuteScriptCommand --> CommandExecutor
ExecuteScriptCommand --> InputHandler
ExecuteScriptCommand --> CommandRequestParser
SaveCommand .down.> FileWriteException

' Factory and registry
CommandRegistry o-- "0..*" CommandContract
CommandFactory .down.> CommandContract
DefaultCommandFactory o-- CommandManager
DefaultCommandFactory o-- CommandExecutor
DefaultCommandFactory o-- CollectionManager
DefaultCommandFactory o-- InputHandler
DefaultCommandFactory o-- CommandRequestParser
DefaultCommandFactory o-- FileManager
DefaultCommandFactory .down.> CommandRegistry
DefaultCommandFactory .down.> Command

' Managers and proxies
CommandExecutor .right.> CommandRequest
CommandExecutor .right.> CommandResponse
CommandManager o-- "0..*" CommandContract
CollectionManager *-- "0..*" SpaceMarine
CollectionManager .right.> AstartesCategory
FileManager .right.> SpaceMarine
FileManager .down.> FileReadException
FileManager .down.> FileWriteException
FileManager .down.> ValidationException
LoggingCommandExecutorProxy o-- CommandExecutor
ValidatingCommandExecutorProxy o-- CommandExecutor
ValidatingCommandExecutorProxy .right.> Validator

' IO dependencies
InputHandler .right.> SpaceMarine
InputHandler .right.> Coordinates
InputHandler .right.> Chapter
InputHandler .right.> AstartesCategory
InputHandler .right.> MeleeWeapon
InputHandler .down.> CommandExecutionException
CommandRequestParser .right.> CommandRequest
CommandRequestParser .right.> Validator
CommandOutput .right.> CommandResponse
CommandOutput .right.> Validator

' Application assembly and entry points
ApplicationContext *-- CommandExecutor
ApplicationContext *-- CommandReader
ApplicationContext *-- CommandRequestParser
ApplicationContext *-- CommandOutput
ApplicationBootstrap .right.> CollectionManager
ApplicationBootstrap .right.> FileManager
ApplicationBootstrap .right.> CommandManager
ApplicationBootstrap .right.> InputHandler
ApplicationBootstrap .right.> CommandReader
ApplicationBootstrap .right.> CommandRequestParser
ApplicationBootstrap .right.> CommandOutput
ApplicationBootstrap .right.> DefaultCommandFactory
ApplicationBootstrap .right.> ValidatingCommandExecutorProxy
ApplicationBootstrap .right.> LoggingCommandExecutorProxy
ApplicationBootstrap .down.> FileReadException
ApplicationRunner o-- ApplicationContext
ApplicationRunner .right.> CommandRequest
ApplicationRunner .right.> CommandResponse
Server .right.> LoggingConfigurator
Server .right.> ApplicationBootstrap
Server .right.> ApplicationContext
Server .right.> ApplicationRunner
Server .right.> Validator
LoggingConfigurator *-- PrettyLogFormatter

' Hidden links for package alignment
Client -[hidden]right- Server
SpaceMarine -[hidden]right- CommandRequest
Command -[hidden]right- CommandFactory
CommandExecutor -[hidden]right- InputHandler
ApplicationContext -[hidden]right- LoggingConfigurator

@enduml
